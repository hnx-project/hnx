//! UART Driver Implementation for Kernel
//!
//! This module implements a kernel-space UART driver that communicates with the user-space
//! UART driver through IPC to handle UART operations.

use core::ptr;
use core::sync::atomic::{AtomicUsize, Ordering};
use crate::kernel_core::ipc::{endpoint_send_sync, IpcMessage, Priority};

// UART register offsets (for fallback/direct access if needed)
const PL011_DR: usize = 0x000;
const PL011_FR: usize = 0x018;

// UART flags
const PL011_FR_RXFE: u32 = 1 << 4;
const PL011_FR_TXFF: u32 = 1 << 5;
const PL011_FR_BUSY: u32 = 1 << 3;

/// UART driver that communicates with user-space driver
pub struct KernelUart {
    base_address: AtomicUsize,
    user_driver_epid: Option<u32>, // Endpoint ID of user-space driver
}

impl KernelUart {
    /// Create a new kernel UART driver instance
    pub const fn new() -> Self {
        Self {
            base_address: AtomicUsize::new(0x0900_0000), // Default base address
            user_driver_epid: None,
        }
    }
    
    /// Initialize the UART driver
    pub fn init(&self) {
        // Initialization is handled by user-space driver
        // We just need to register with the device manager
        crate::info!("Kernel UART driver initialized");
    }
    
    /// Set the endpoint ID of the user-space driver
    pub fn set_user_driver_epid(&mut self, epid: u32) {
        self.user_driver_epid = Some(epid);
    }
    
    /// Write a character to the UART through user-space driver
    pub fn putc(&self, c: u8) {
        // If we have a user-space driver, send the character through IPC
        if let Some(epid) = self.user_driver_epid {
            // Create IPC message to send character to user-space driver
            let mut data = [0u8; 256];
            data[0] = c; // Character to send
            
            let msg = IpcMessage {
                src_pid: 0, // Kernel PID
                dst_epid: epid,
                op: 0x100, // Custom opcode for UART putc
                priority: Priority::High,
                data_len: 1,
                data,
                timestamp: crate::arch::timer::now_us(),
            };
            
            if let Err(e) = endpoint_send_sync(epid, msg) {
                crate::error!("Failed to send UART character to user-space driver: {:?}", e);
                // Fallback to direct hardware access if IPC fails
                self.putc_direct(c);
            }
        } else {
            // Fallback to direct hardware access if no user-space driver
            self.putc_direct(c);
        }
    }
    
    /// Direct hardware access for putc (fallback)
    fn putc_direct(&self, c: u8) {
        unsafe {
            let base = self.base_address.load(Ordering::Relaxed) as *mut u32;
            let mut ch = c;
            if ch < 0x20 && ch != b'\n' && ch != b'\t' { return; }
            if ch >= 0x80 { return; }
            if ch == b'\n' {
                while (ptr::read_volatile(base.add(PL011_FR / 4)) & PL011_FR_TXFF) != 0 { core::hint::spin_loop(); }
                while (ptr::read_volatile(base.add(PL011_FR / 4)) & PL011_FR_BUSY) != 0 { core::hint::spin_loop(); }
                ptr::write_volatile(base.add(PL011_DR / 4), b'\r' as u32);
            }
            while (ptr::read_volatile(base.add(PL011_FR / 4)) & PL011_FR_TXFF) != 0 { core::hint::spin_loop(); }
            while (ptr::read_volatile(base.add(PL011_FR / 4)) & PL011_FR_BUSY) != 0 { core::hint::spin_loop(); }
            ptr::write_volatile(base.add(PL011_DR / 4), ch as u32);
        }
    }
    
    /// Read a character from the UART through user-space driver
    pub fn getc(&self) -> Option<u8> {
        // If we have a user-space driver, read the character through IPC
        if let Some(epid) = self.user_driver_epid {
            // In a real implementation, we would receive characters through IPC
            // For now, we'll just return None to indicate no data
            None
        } else {
            // Fallback to direct hardware access if no user-space driver
            self.getc_direct()
        }
    }
    
    /// Direct hardware access for getc (fallback)
    fn getc_direct(&self) -> Option<u8> {
        unsafe {
            let base = self.base_address.load(Ordering::Relaxed) as *mut u32;
            if ptr::read_volatile(base.add(PL011_FR / 4)) & PL011_FR_RXFE != 0 {
                None
            } else {
                Some(ptr::read_volatile(base.add(PL011_DR / 4)) as u8)
            }
        }
    }
    
    /// Set the base address of the UART hardware
    pub fn set_base(&self, addr: usize) {
        self.base_address.store(addr, Ordering::Relaxed);
    }
}

/// Global kernel UART instance
pub static KERNEL_UART: KernelUart = KernelUart::new();